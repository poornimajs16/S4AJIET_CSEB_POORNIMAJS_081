class program {
    public static void main(String[] args) {
        int n=10;
        int m=5;
        int temp;
        System.out.println("Before swapping n:"+n);
        System.out.println("Before swapping m:"+m);
        n+=m;
        m=n-m;
        n-=m;
        System.out.println("After swapping n:"+n);
        System.out.println("After swapping m:"+m);
    }                                                         
}
