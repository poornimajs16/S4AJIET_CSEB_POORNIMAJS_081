class program {
    public static void main(String[] args) {
        int a=10;
        int b=5;
        System.out.println("Before swapping n:"+a);
        System.out.println("Before swapping m:"+b);
        a=a^b;
        b=a^b;
        a=a^b;
        System.out.println("After swapping n:"+a);
        System.out.println("After swapping m:"+b);
    }                                                         
}
