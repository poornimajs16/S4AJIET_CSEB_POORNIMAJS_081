class Bottle {
    String brand;
    String color;
    int volume;

    int currentVolume = 0;
    boolean isOpen = false;
    boolean isClosed = true;
    boolean isFull = false;
    boolean isEmpty = true;

    
    Bottle(String brand, String color, int volume) {
        this.brand = brand;
        this.color = color;
        this.volume = volume;
    }

  
    public void openCap() {
        System.out.println("Bottle is open");
        this.isOpen = true;
        this.isClosed = false;
    }

   
    public void closeCap() {
        System.out.println("Bottle is closed");
        this.isClosed = true;
        this.isOpen = false;
    }

   
    public void drink(int consumed) {
        System.out.println("Drinking " + consumed + " ml of water");
        this.currentVolume -= consumed;

        if (this.currentVolume <= 0) {
            this.currentVolume = 0;
            this.isEmpty = true;
        }

        if (this.currentVolume != this.volume) {
            this.isFull = false;
        }
    }


    public void fillWater(int amount) {
        System.out.println("Filling " + amount + " ml of water");
        this.currentVolume += amount;

        if (this.currentVolume >= this.volume) {
            this.currentVolume = this.volume;
            this.isFull = true;
        }

        if (this.currentVolume > 0) {
            this.isEmpty = false;
        }
    }

  
    public void display() {
        System.out.printf( "%s,%s,%d,%d,%b,%b,%b.%b",this.brand,this.color, this.volume,this.currentVolume,this.isFull, this.isEmpty,this.isOpen, this.isClosed);
    }
}

public class Main {
    public static void main(String[] args) {
        Bottle Milton = new Bottle("Milton", "Black", 750);

        Milton.display();
        Milton.openCap();
        Milton.display();
        Milton.fillWater(100);
        Milton.display();
        Milton.drink(50);
        Milton.fillWater(750);
        Milton.display();
        Milton.drink(75);
        Milton.display();
    }
}
